{
  "kind": "collectionType",
  "collectionName": "magazines",
  "info": {
    "singularName": "magazine",
    "pluralName": "magazines",
    "displayName": "Magazine",
    "description": "Numéros de magazines hébergés sur Calameo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "image_couverture": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "lien_calameo": {
      "type": "string",
      "required": true,
      "regex": "^https?://.+"
    },
    "date_publication": {
      "type": "date",
      "required": true
    }
  }
}
