{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Actualités du site — brèves et articles de fond"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre",
      "required": true
    },
    "chapo": {
      "type": "text",
      "required": true
    },
    "contenu": {
      "type": "richtext",
      "required": true
    },
    "image_couverture": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "format": {
      "type": "enumeration",
      "enum": ["breve", "article_de_fond"],
      "required": true
    },
    "secteur": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::structure.structure",
      "inversedBy": "articles"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "articles"
    },
    "date_publication": {
      "type": "date",
      "required": true
    },
    "reserve_adherents": {
      "type": "boolean",
      "default": false,
      "required": true
    }
  }
}
