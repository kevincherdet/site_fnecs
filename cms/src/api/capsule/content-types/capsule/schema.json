{
  "kind": "collectionType",
  "collectionName": "capsules",
  "info": {
    "singularName": "capsule",
    "pluralName": "capsules",
    "displayName": "Capsule",
    "description": "Capsules pédagogiques interactives (conventions collectives)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "image_couverture": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "lien_genially": {
      "type": "string",
      "required": true,
      "regex": "^https?://.+"
    },
    "secteur": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::structure.structure",
      "inversedBy": "capsules"
    }
  }
}
