{
  "kind": "collectionType",
  "collectionName": "presses",
  "info": {
    "singularName": "presse",
    "pluralName": "presses",
    "displayName": "Presse",
    "description": "Communiqués, dossiers de presse, photothèque, revue de presse"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["communique", "dossier_de_presse", "photo_kit_media", "revue_de_presse"],
      "required": true
    },
    "contenu": {
      "type": "richtext"
    },
    "fichier": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files"]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "date_publication": {
      "type": "date",
      "required": true
    }
  }
}
