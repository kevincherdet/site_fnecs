# ───────── Dépendances ─────────
**/node_modules/
**/.pnp
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# ───────── Builds Next.js (frontend) ─────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
**/*.tsbuildinfo
frontend/next-env.d.ts

# ───────── Strapi (cms) ─────────
cms/.strapi/
cms/.tmp/
cms/dist/
cms/build/
cms/.cache/
cms/exports/
cms/.strapi-updater.json

# ───────── Variables d'environnement ─────────
# Jamais commité, sauf les fichiers .env.example
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.production
!**/.env.example

# ───────── Logs ─────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ───────── Tests / coverage ─────────
**/coverage/

# ───────── OS / éditeurs ─────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ───────── Backup de l'ancien .git du frontend (à supprimer manuellement) ─────────
frontend/.git.old/

# ───────── Archives et docs locales ─────────
Archives/

# ───────── Documents bureautiques racine (sauvegardés par OneDrive) ─────────
/*.pdf
/*.docx
/*.xlsx
/*.pptx
